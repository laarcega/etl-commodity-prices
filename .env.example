# ─────────────────────────────────────────────────────────────────────────────
# ETL Commodity Prices — Environment Configuration
# Copy this file to .env and fill in all values before running the pipeline.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# World Bank commodity prices page (DOM scrape for XLSX link discovery)
URL_WB_DOM=https://www.worldbank.org/en/research/commodity-markets

# BSP Exchange Rate XLSX URL (direct link to the file)
URL_BSP=https://www.bsp.gov.ph/statistics/external/pesodollar.xlsx

# Commodity columns to extract from World Bank XLSX (comma-separated)
# These must match column names in the World Bank CMO Price file.
# To add a commodity: edit this value only — zero script changes needed.
WB_COLUMNS=phosphate_rock,dap,tsp,urea,potassium_chloride

# Target currency for peso conversion
TARGET_CURRENCY=PHP

# Load target: "sqlite" or "postgres"
LOAD_TARGET=sqlite

# SQLite database path (used when LOAD_TARGET=sqlite)
SQLITE_PATH=etl.sqlite

# PostgreSQL connection string (used when LOAD_TARGET=postgres)
# Format: postgresql://user:password@host:5432/dbname
PG_CONNECTION_STRING=

# Pipeline safety constraints
MAX_RETRIES=3
TIMEOUT_SEC=30
